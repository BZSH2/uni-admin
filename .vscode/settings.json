{
  "files.associations": {
    "pages.json": "jsonc",
    "manifest.json": "jsonc"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "never"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.enable": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, tsconfig.*.json, tsconfig.json, .gitignore, .gitattributes, .npmrc",
    "vite.config.ts": "*.html, uno.config.ts, unh.config.ts, vitest.config.ts",
    "tsconfig.json": "tsconfig.*.json",
    "eslint.config.ts": ".eslintignore, .prettierrc.json, .prettierignore, .stylelintrc.json, .stylelintignore, .commitlintrc.json, .lintstagedrc.json, .czrc, .eslintrc-auto-import.json",
    "README.md": "*.md",
    ".env": ".env.*",
    "Dockerfile": ".dockerignore, docker-compose.prod.yml"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "nvue",
    "uvue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "gql",
    "graphql",
    "astro",
    "svelte",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
  "cSpell.words": [
    "alish",
    "autofocus",
    "automator",
    "autoscan",
    "bzsh",
    "climblee",
    "darkmode",
    "dcloudio",
    "easycom",
    "echarts",
    "hbuilderx",
    "healthz",
    "iconfont",
    "iconify",
    "kuaishou",
    "macarons",
    "miniprogram",
    "njsproj",
    "ntvs",
    "nvue",
    "quickapp",
    "raddar",
    "splashscreen",
    "stacktracey",
    "toutiao",
    "unconfig",
    "uniapp",
    "unocss",
    "VCONSOLE",
    "vueuse",
    "webp",
    "weixin"
  ]
}
